{
  "include": [
    "~/.config/waybar/modules/*.jsonc",
    "~/.config/waybar/modules/custom/*jsonc",
    "~/.config/waybar/modules/custom/icon-wrapper/*jsonc",
    "~/.config/waybar/modules/custom/hardware/*.jsonc",
    "~/.config/waybar/modules/extras/*.jsonc",
  ],

  /*-----------
     layout
  -----------*/

  "modules-center": [
    "group/hardware",
    "clock#date",
    "hyprland/workspaces",
    "clock#time",
    "group/icon-wrapper",
  ],

  /*-----------
     options
  -----------*/

  // "expand-center":
  // "expand-left":
  // "expand-right":
  "layer": "top",
